#compdef jv

_jv() {
  local -a commands
  commands=(
    'create:Create a new Java project'
    'init:Initialize project in current directory'
    'explain:Show the detected build/run plan'
    'doctor:Inspect Java project state'
    'history:Show recent JV run history'
    'events:Alias for history'
    'retry:Retry the latest failed or blocked JV run'
    'watch:Re-run when Java source files change'
    'compile:Compile Java files'
    'run:Infer, explain, compile, and run'
    'remember:Remember generated JV memory'
    'forget:Remove generated JV memory'
    'clean:Remove compiled class files'
    'help:Show help'
    'version:Show version'
  )

  _arguments \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '1:command:->command' \
    '*::arg:->args'

  case "$state" in
    command)
      _describe 'command' commands
      ;;
    args)
      case "$words[2]" in
        history|events) _arguments '--limit[limit records]' '--failures[show failures only]' '--json[emit JSON]' ;;
        retry) _arguments '--dry-run[print selected retry]' '--json[emit JSON]' ;;
        doctor) _arguments '--json[emit JSON]' ;;
        remember|forget) _values 'memory key' main ;;
      esac
      ;;
  esac
}

_jv "$@"
